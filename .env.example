# Odoo backend (server-only — never PUBLIC_ prefixed)
ODOO_URL=https://your-odoo-instance.example.com
ODOO_DB=your_db_name
# Odoo administrator login + API key. Used ONLY for signup provisioning and
# admin-key writes in the proxy — never exposed to the browser.
ODOO_USERNAME=admin@example.com
ODOO_API_KEY=your_admin_api_key

# Cloudflare TURN (voice relay). Dashboard -> Realtime -> TURN -> create key.
# Optional: without these, voice is STUN-only (fails across CGNAT/mobile NATs).
CF_TURN_KEY_ID=your_turn_key_id
CF_TURN_API_TOKEN=your_turn_api_token
